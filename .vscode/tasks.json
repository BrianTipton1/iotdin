{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mkdir",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/build"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "odin build src -debug -out:build/iotdin -collection:iotdin=src",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "mkdir"
      ],
      "problemMatcher": []
    },
    {
      "label": "tests",
      "type": "shell",
      "command": "odin test tests/ -all-packages -collection:iotdin=src",
      "group": {
        "kind": "test",
        "isDefault": true
      },
    },
    {
      "label": "format all",
      "type": "shell",
      "command": "odinfmt",
      "args": [
        "-w",
        "${workspaceFolder}"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}