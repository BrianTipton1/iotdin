{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mkdir",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/bin"
    },
    {
      "label": "build broker",
      "type": "shell",
      "command": "odin",
      "args": [
        "build",
        "src/broker",
        "-debug",
        "-out:bin/iotdin_broker",
        "-collection:iotdin=src"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "mkdir"
      ],
      "problemMatcher": []
    },
    {
      "label": "build client",
      "type": "shell",
      "command": "odin",
      "args": [
        "build",
        "src/client",
        "-debug",
        "-out:bin/iotdin_client",
        "-collection:iotdin=src"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "mkdir"
      ],
      "problemMatcher": []
    },
    {
      "label": "tests",
      "type": "shell",
      "command": "odin",
      "args": [
        "test",
        "tests/",
        "-all-packages",
        "-collection:iotdin=src",
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
    },
    {
      "label": "format all",
      "type": "shell",
      "command": "odinfmt",
      "args": [
        "-w",
        "${workspaceFolder}"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build_tests",
      "type": "shell",
      "command": "odin",
      "args": [
        "build",
        "${workspaceFolder}/tests",
        "-build-mode:test",
        "-all-packages",
        "-debug",
        "-out:${workspaceFolder}/bin/tests_debug",
        "-collection:iotdin=src",
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      },
      "dependsOn": [
        "mkdir"
      ],
    }
  ]
}